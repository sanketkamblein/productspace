<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio: Intelligent Controls Compliance System | Asian Paints × SAP</title>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    /* ───────────────────────────────────────────
       EXACT ASIAN PAINTS PRESENTATION PALETTE
       Extracted from AsianPaints_Invent_Phase2.pptx
    ─────────────────────────────────────────── */
    :root {
      --dk1:        #0C343D;   /* TEXT_1 — primary dark teal */
      --dk2:        #134F5C;   /* TEXT_2 — medium dark teal */
      --lt1:        #F3F7F8;   /* BACKGROUND_1 — slide background */
      --lt2:        #45818E;   /* accent lines, name fills, table numbers */
      --accent1:    #76A5AF;   /* light teal — box borders, illustrations */
      --accent2:    #D9EAD3;   /* pale green */
      --accent3:    #88ADA5;   /* muted teal */
      --accent4:    #F3F3F3;   /* very light gray */
      --panel-gray: #F7F7F7;   /* large background panel (arch slide) */
      --hyperlink:  #0097A7;   /* followed hyperlink teal */
      --white:      #FFFFFF;

      /* Semantic risk colors (kept minimal, teal-adjacent) */
      --risk-high:  #8B1A1A;
      --risk-high-bg: #FDECEA;
      --risk-med:   #7A4A00;
      --risk-med-bg: #FFF3E0;
      --risk-low:   #1B4D3E;
      --risk-low-bg: #E8F5E9;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Lato', Arial, sans-serif;
      background: var(--lt1);
      color: var(--dk1);
      line-height: 1.72;
      font-size: 14px;
    }

    /* ══════════════════════════════════════
       COVER SLIDE — mirrors Slide 1 style
    ══════════════════════════════════════ */
    .cover {
      background: var(--lt1);
      display: flex;
      align-items: stretch;
      min-height: 340px;
      border-bottom: 3px solid var(--lt2);
      position: relative;
      overflow: hidden;
    }

    /* Left: geometric illustration panel (teal blocks, replicating cover art) */
    .cover-art {
      width: 320px;
      flex-shrink: 0;
      background: var(--dk2);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cover-art::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        linear-gradient(135deg, var(--dk1) 0%, var(--dk2) 50%, var(--lt2) 100%);
    }
    /* Geometric blocks replicating the vector illustration palette */
    .cover-art-inner {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
    }
    .geo { position: absolute; }
    .geo-1  { width:80px;  height:80px;  top:20px;  left:20px;  background:var(--lt2);    opacity:0.7; }
    .geo-2  { width:50px;  height:120px; top:20px;  left:110px; background:var(--accent1); opacity:0.5; }
    .geo-3  { width:120px; height:50px;  top:60px;  left:160px; background:var(--dk1);    opacity:0.9; }
    .geo-4  { width:60px;  height:60px;  top:140px; left:30px;  background:var(--accent2); opacity:0.8; }
    .geo-5  { width:90px;  height:40px;  top:160px; left:120px; background:var(--accent3); }
    .geo-6  { width:40px;  height:90px;  top:200px; left:220px; background:var(--lt2);    opacity:0.6; }
    .geo-7  { width:100px; height:30px;  top:240px; left:50px;  background:var(--accent1); opacity:0.4; }
    .geo-8  { width:30px;  height:70px;  top:260px; left:170px; background:var(--dk2);    opacity:0.8; }
    /* dots */
    .dot  { border-radius:50%; }
    .dot-1 { width:14px; height:14px; top:110px; left:80px;  background:var(--accent2); }
    .dot-2 { width:10px; height:10px; top:180px; left:190px; background:var(--white);   opacity:0.7; }
    .dot-3 { width:18px; height:18px; top:220px; left:260px; background:var(--accent1); }

    /* Right: text */
    .cover-text {
      flex: 1;
      padding: 48px 52px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    /* The decorative teal line above title (from Slide 1) */
    .cover-line {
      width: 280px;
      height: 2.5px;
      background: var(--lt2);
      margin-bottom: 18px;
    }
    .cover-eyebrow {
      font-family: 'Lato', sans-serif;
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--lt2);
      margin-bottom: 10px;
    }
    .cover-title {
      font-family: 'Sora', sans-serif;
      font-size: 32px;
      font-weight: 700;
      color: var(--dk1);
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .cover-subtitle {
      font-size: 14px;
      color: var(--dk2);
      margin-bottom: 28px;
      font-weight: 400;
    }
    .cover-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .cover-tag {
      background: var(--dk2);
      color: var(--lt1);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 12px;
      /* Sharp rectangles — no border radius, matches presentation */
    }

    /* ══════════════════════════════════════
       META STRIP — the 6-field summary bar
    ══════════════════════════════════════ */
    .meta-strip {
      background: var(--dk2);
      color: var(--lt1);
    }
    .meta-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
    }
    .meta-cell {
      padding: 14px 20px;
      border-right: 1px solid rgba(255,255,255,0.15);
    }
    .meta-cell:last-child { border-right: none; }
    .meta-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--accent1);
      margin-bottom: 3px;
    }
    .meta-val {
      font-size: 12px;
      font-weight: 700;
      color: var(--lt1);
    }

    /* ══════════════════════════════════════
       LAYOUT
    ══════════════════════════════════════ */
    .page { max-width: 1100px; margin: 0 auto; padding: 0 40px; }
    .main { padding: 48px 0 80px; }

    /* ══════════════════════════════════════
       SECTION HEADING — mirrors slide header
    ══════════════════════════════════════ */
    .section { margin-bottom: 60px; }

    .section-head {
      border-bottom: 2px solid var(--lt2);
      padding-bottom: 8px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    /* Circular numbered badge from Slide 6 ovals */
    .sec-num {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--dk2);
      color: var(--lt1);
      font-size: 13px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      border: 2px solid var(--lt1);
      box-shadow: 0 0 0 2px var(--dk2);
    }
    .sec-title {
      font-family: 'Sora', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--dk1);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Sub-headings within sections */
    h3 {
      font-size: 14px;
      font-weight: 700;
      color: var(--dk2);
      margin: 26px 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    p { margin-bottom: 12px; font-size: 14px; }
    ul, ol { padding-left: 20px; margin-bottom: 14px; }
    li { margin-bottom: 5px; font-size: 14px; }
    strong { font-weight: 700; }
    em { font-style: italic; }

    /* ══════════════════════════════════════
       STAT BLOCKS
    ══════════════════════════════════════ */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1px;
      background: var(--accent1);
      border: 1px solid var(--accent1);
      margin-bottom: 24px;
    }
    .stat-cell {
      background: var(--white);
      padding: 20px 18px;
      text-align: center;
    }
    .stat-num {
      font-family: 'Sora', sans-serif;
      font-size: 30px;
      font-weight: 800;
      color: var(--dk2);
      line-height: 1;
    }
    .stat-lbl {
      font-size: 11px;
      color: var(--lt2);
      margin-top: 5px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    /* ══════════════════════════════════════
       TABLES — exact Slide 8 table style
       Teal number column + border dk2
    ══════════════════════════════════════ */
    .tbl-wrap { overflow-x: auto; margin-bottom: 20px; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
    }
    thead tr {
      background: var(--dk2);
      color: var(--lt1);
    }
    th {
      padding: 10px 14px;
      text-align: left;
      font-weight: 700;
      font-size: 10.5px;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      border: 1px solid var(--dk2);
    }
    td {
      padding: 10px 14px;
      border: 1px solid var(--dk2);
      vertical-align: top;
      font-size: 13.5px;
    }
    /* Number column — teal fill, white text (Slide 8 table style) */
    td.num-col {
      background: var(--lt2);
      color: var(--lt1);
      font-weight: 700;
      font-size: 10px;
      text-align: center;
      width: 40px;
    }
    tbody tr:nth-child(even) td:not(.num-col) { background: var(--panel-gray); }
    tbody tr:hover td:not(.num-col) { background: var(--accent2); }

    /* ══════════════════════════════════════
       CARDS — white panels on lt1 background
    ══════════════════════════════════════ */
    .card {
      background: var(--white);
      border: 1px solid var(--accent1);
      padding: 20px 22px;
      margin-bottom: 14px;
    }
    .card-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    @media (max-width: 680px) { .card-grid { grid-template-columns: 1fr; } }

    /* Teal left border variant */
    .card-accent {
      border-left: 4px solid var(--lt2);
    }

    /* ══════════════════════════════════════
       BLOCKQUOTE
    ══════════════════════════════════════ */
    blockquote {
      border-left: 4px solid var(--lt2);
      background: var(--accent2);
      padding: 14px 20px;
      margin: 18px 0;
      font-style: italic;
      color: var(--dk2);
      font-size: 14px;
    }
    blockquote footer {
      margin-top: 8px;
      font-style: normal;
      font-size: 11px;
      color: var(--lt2);
      font-weight: 700;
    }

    /* ══════════════════════════════════════
       BADGES
    ══════════════════════════════════════ */
    .badge {
      display: inline-block;
      padding: 2px 9px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }
    .badge-high { background: var(--risk-high-bg); color: var(--risk-high); border: 1px solid var(--risk-high); }
    .badge-med  { background: var(--risk-med-bg);  color: var(--risk-med);  border: 1px solid var(--risk-med);  }
    .badge-low  { background: var(--risk-low-bg);  color: var(--risk-low);  border: 1px solid var(--risk-low);  }
    .badge-teal { background: var(--dk2); color: var(--lt1); }

    /* ══════════════════════════════════════
       ARCHITECTURE BLOCK — Slide 5 style
       Dark lower panel + light upper panel
    ══════════════════════════════════════ */
    .arch-outer {
      background: var(--panel-gray);
      border: 1px solid var(--accent1);
      margin-bottom: 24px;
      overflow: hidden;
    }
    .arch-label {
      background: var(--dk1);
      color: var(--accent1);
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 7px 16px;
    }
    .arch-layers {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .arch-layer {
      display: flex;
      align-items: stretch;
    }
    .arch-layer-label {
      background: var(--dk2);
      color: var(--lt1);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 12px 8px;
      min-width: 32px;
      text-align: center;
      flex-shrink: 0;
    }
    .arch-layer-body {
      flex: 1;
      padding: 14px 18px;
      border-bottom: 1px solid var(--accent1);
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      background: var(--white);
    }
    .arch-layer:last-child .arch-layer-body { border-bottom: none; background: var(--dk1); }
    .arch-layer:last-child .arch-layer-label { background: var(--dk1); }
    .arch-chip {
      background: var(--lt1);
      border: 1px solid var(--accent1);
      color: var(--dk2);
      font-size: 10.5px;
      font-weight: 700;
      padding: 5px 12px;
    }
    .arch-chip-dark {
      background: var(--dk2);
      border: 1px solid var(--lt2);
      color: var(--lt1);
      font-size: 10.5px;
      font-weight: 700;
      padding: 5px 12px;
    }
    .arch-arrow {
      color: var(--lt2);
      font-size: 16px;
      font-weight: 700;
    }

    /* ══════════════════════════════════════
       PIPELINE — Slide 6 user journey style
       Horizontal numbered ovals + line
    ══════════════════════════════════════ */
    .pipeline-h {
      position: relative;
      padding: 32px 0 12px;
      margin-bottom: 24px;
    }
    .pipeline-track {
      position: absolute;
      top: 16px;
      left: 20px;
      right: 20px;
      height: 3px;
      background: var(--dk1);
    }
    .pipeline-steps {
      display: flex;
      justify-content: space-between;
      position: relative;
    }
    .ps {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      gap: 10px;
    }
    /* Oval badge from Slide 6 */
    .ps-num {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--dk2);
      color: var(--lt1);
      font-size: 13px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid var(--lt1);
      box-shadow: 0 0 0 2px var(--dk2);
      z-index: 1;
      flex-shrink: 0;
    }
    .ps-body {
      background: var(--white);
      border: 1px solid var(--accent1);
      padding: 10px 12px;
      font-size: 12px;
      text-align: center;
      width: 100%;
      line-height: 1.4;
    }
    .ps-body strong {
      display: block;
      color: var(--dk2);
      margin-bottom: 3px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* ══════════════════════════════════════
       MOSCOW
    ══════════════════════════════════════ */
    .moscow-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    @media (max-width: 680px) { .moscow-grid { grid-template-columns: 1fr; } }
    .moscow-card { padding: 18px 20px; border: 1px solid; }
    .moscow-must   { background: var(--risk-high-bg);  border-color: #c0a0a0; }
    .moscow-should { background: var(--risk-med-bg);   border-color: #c0a870; }
    .moscow-could  { background: var(--accent2);        border-color: var(--accent3); }
    .moscow-wont   { background: var(--panel-gray);     border-color: var(--accent1); }
    .moscow-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 10px;
      padding: 3px 10px;
      display: inline-block;
    }
    .moscow-must .moscow-label   { background: var(--risk-high); color: #fff; }
    .moscow-should .moscow-label { background: var(--risk-med);  color: #fff; }
    .moscow-could .moscow-label  { background: var(--dk2);        color: var(--lt1); }
    .moscow-wont .moscow-label   { background: var(--lt2);        color: var(--lt1); }
    .moscow-card ul { padding-left: 16px; font-size: 13px; }
    .moscow-card li { margin-bottom: 4px; }

    /* ══════════════════════════════════════
       OKR BLOCKS
    ══════════════════════════════════════ */
    .okr-block { margin-bottom: 14px; border: 1px solid var(--dk2); }
    .okr-obj {
      background: var(--dk2);
      color: var(--lt1);
      padding: 10px 18px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .okr-krs { background: var(--white); padding: 14px 18px; }
    .okr-kr {
      display: flex;
      gap: 12px;
      margin-bottom: 9px;
      align-items: flex-start;
      font-size: 13.5px;
    }
    .okr-kr:last-child { margin-bottom: 0; }
    .kr-badge {
      background: var(--lt2);
      color: var(--lt1);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 2px 7px;
      white-space: nowrap;
      margin-top: 3px;
      flex-shrink: 0;
    }

    /* ══════════════════════════════════════
       ROADMAP — teal timeline
    ══════════════════════════════════════ */
    .roadmap {
      border-left: 3px solid var(--lt2);
      padding-left: 28px;
      margin-bottom: 16px;
    }
    .rm-phase { position: relative; margin-bottom: 28px; }
    .rm-phase::before {
      content: '';
      position: absolute;
      left: -36px; top: 5px;
      width: 16px; height: 16px;
      border-radius: 50%;
      background: var(--dk2);
      border: 2px solid var(--lt1);
      box-shadow: 0 0 0 2px var(--dk2);
    }
    .rm-label {
      font-size: 9px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--lt2); margin-bottom: 2px;
    }
    .rm-title {
      font-family: 'Sora', sans-serif;
      font-size: 15px; font-weight: 700;
      color: var(--dk1); margin-bottom: 3px;
    }
    .rm-time { font-size: 11px; color: var(--lt2); margin-bottom: 5px; font-weight: 700; }
    .rm-body  { font-size: 13.5px; margin-bottom: 6px; }
    .rm-gate {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--accent2);
      border: 1px solid var(--accent3);
      padding: 3px 10px;
      font-size: 11.5px;
      font-weight: 700;
      color: var(--risk-low);
    }

    /* ══════════════════════════════════════
       DECISION CARDS
    ══════════════════════════════════════ */
    .dec-card {
      border: 1px solid var(--accent1);
      margin-bottom: 20px;
      background: var(--white);
    }
    .dec-head {
      background: var(--dk2);
      padding: 11px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .dec-num {
      width: 26px; height: 26px;
      background: var(--lt2);
      color: var(--lt1);
      font-size: 12px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .dec-title { font-size: 14px; font-weight: 700; color: var(--lt1); }
    .dec-body { padding: 16px 18px; }
    .options-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 10px 0;
    }
    @media (max-width: 600px) { .options-row { grid-template-columns: 1fr; } }
    .opt {
      border: 1px solid var(--accent1);
      padding: 12px 14px;
      font-size: 13px;
    }
    .opt.selected { border-color: var(--dk2); border-width: 2px; background: var(--accent2); }
    .opt.rejected { opacity: 0.65; background: var(--panel-gray); }
    .opt-label {
      font-size: 9.5px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1px;
      margin-bottom: 5px; padding: 2px 8px; display: inline-block;
    }
    .opt-label.sel { background: var(--dk2); color: var(--lt1); }
    .opt-label.rej { background: var(--accent1); color: var(--lt1); }
    .rationale {
      background: var(--accent2);
      border-left: 3px solid var(--lt2);
      padding: 9px 14px;
      font-size: 13px;
      margin-top: 10px;
    }

    /* ══════════════════════════════════════
       LESSONS
    ══════════════════════════════════════ */
    .lesson {
      display: flex;
      gap: 0;
      border: 1px solid var(--accent1);
      margin-bottom: 10px;
      background: var(--white);
    }
    .lesson-tag {
      background: var(--lt2);
      color: var(--lt1);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 12px 7px;
      min-width: 30px;
      text-align: center;
      flex-shrink: 0;
    }
    .lesson-body {
      padding: 14px 18px;
      font-size: 13.5px;
    }
    .lesson-body strong { color: var(--dk2); display: block; margin-bottom: 3px; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* ══════════════════════════════════════
       WIREFRAME MOCKUPS — Slide 5/7 style
    ══════════════════════════════════════ */
    .mockup {
      border: 1px solid var(--accent1);
      background: var(--panel-gray);
      margin-bottom: 20px;
    }
    .mockup-bar {
      background: var(--dk1);
      padding: 8px 16px;
      display: flex;
